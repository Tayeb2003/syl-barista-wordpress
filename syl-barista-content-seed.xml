    <item>
        <title>Menu</title>
        <link>https://example.com/menu/</link>
        <pubDate>Mon, 20 Apr 2026 10:00:03 +0000</pubDate>
        <dc:creator><![CDATA[admin]]></dc:creator>
        <guid isPermaLink="false">https://example.com/?page_id=103</guid>
        <description></description>
        <content:encoded><![CDATA[
<!-- wp:heading -->
<h2>Espresso Signatures</h2>
<!-- /wp:heading -->
<!-- wp:list -->
<ul><li><strong>Velvet Cortado</strong> - Double ristretto, silky milk texture, caramel-citrus finish. - $7</li><li><strong>Noir Americano</strong> - Long espresso with dark chocolate depth and clean finish. - $6</li><li><strong>Syl Espresso Flight</strong> - Three-origin tasting progression with sensory notes. - $12</li></ul>
<!-- /wp:list -->
<!-- wp:heading -->
<h2>Milk and House Lattes</h2>
<!-- /wp:heading -->
<!-- wp:list -->
<ul><li><strong>Syl Saffron Latte</strong> - Saffron-cardamom infusion, steamed milk, floral sweetness. - $9</li><li><strong>Midnight Mocha</strong> - Dark cocoa blend, dense crema, smooth mouthfeel. - $8</li><li><strong>Vanilla Bean Flat White</strong> - Microfoam precision with Madagascar vanilla aroma. - $8</li></ul>
<!-- /wp:list -->
<!-- wp:heading -->
<h2>Slow Bar and Specialty</h2>
<!-- /wp:heading -->
<!-- wp:list -->
<ul><li><strong>V60 Reserve Pour Over</strong> - Rotating micro-lot, transparent acidity, tea-like body. - $10</li><li><strong>Cold Bloom</strong> - 18-hour cold extraction with citrus and cacao profile. - $8</li><li><strong>Cascara Spark</strong> - Cascara infusion, sparkling finish, lightly sweet. - $7</li></ul>
<!-- /wp:list -->
<!-- wp:heading -->
<h2>Pastry Pairings</h2>
<!-- /wp:heading -->
<!-- wp:list -->
<ul><li><strong>Butter Croissant</strong> - French-style lamination, baked daily. - $5</li><li><strong>Pistachio Rose Tart</strong> - Nut-forward cream with subtle floral top notes. - $7</li><li><strong>Dark Chocolate Financier</strong> - Almond crumb, deep cocoa finish. - $6</li></ul>
<!-- /wp:list -->
        ]]></content:encoded>
